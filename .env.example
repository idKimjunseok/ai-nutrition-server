#
# 로컬 개발용 환경 변수 예시 파일입니다.
# - 이 파일은 커밋해도 되지만, 실제 키를 넣은 `.env`는 커밋하지 마세요(.gitignore에 포함됨).
#
# Google AI Studio(Gemini Developer API) 키
GOOGLE_API_KEY=PASTE_YOUR_KEY_HERE

# Anthropic(Claude) API 키
ANTHROPIC_API_KEY=PASTE_YOUR_KEY_HERE

# Claude 모델 ID (Claude 3.5 는 API에서 더 이상 제공되지 않을 수 있음 — Sonnet 4.6 등으로 지정)
# CLAUDE_MODEL_ID=claude-sonnet-4-6

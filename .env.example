#
# 로컬 개발용 환경 변수 예시 파일입니다.
# - 이 파일은 커밋해도 되지만, 실제 키를 넣은 `.env`는 커밋하지 마세요(.gitignore에 포함됨).
#
# Google AI Studio(Gemini Developer API) 키
GOOGLE_API_KEY=PASTE_YOUR_KEY_HERE

# Anthropic(Claude) API 키
ANTHROPIC_API_KEY=PASTE_YOUR_KEY_HERE

# Claude 모델 ID (Claude 3.5 는 API에서 더 이상 제공되지 않을 수 있음 — Sonnet 4.6 등으로 지정)
# CLAUDE_MODEL_ID=claude-sonnet-4-6

# API Key 인증 (X-API-Key 헤더)
# 미설정 시 인증 스킵 (로컬 개발용). 운영 환경에서는 반드시 설정하세요.
# 생성: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# 피드백 메일 발송 (Resend, https://resend.com)
# RESEND_API_KEY 발급: Resend 대시보드 → API Keys
RESEND_API_KEY=
# 피드백을 받을 수신 이메일
FEEDBACK_EMAIL_TO=
# 발신자 (도메인 인증 전이면 onboarding@resend.dev 사용 가능)
# FEEDBACK_EMAIL_FROM=onboarding@resend.dev
